<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>About Us | Apni Dukaan</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background-color: #f4f4f4;
        }

        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 50px;
            background-color: #333;
        }

        .logo {
            color: white;
            font-size: 22px;
            font-weight: bold;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
            font-size: 16px;
            transition: 0.3s;
        }

        .nav-links a:hover {
            color: #ffd700;
        }

        /* About Section */
        .about {
            padding: 60px 20px;
            text-align: center;
        }

        .about h1 {
            font-size: 40px;
            margin-bottom: 20px;
            color: #333;
        }

        .about p {
            max-width: 800px;
            margin: auto;
            font-size: 18px;
            line-height: 1.6;
            color: #555;
        }

        /* Mission Section */
        .mission {
            margin-top: 40px;
        }

        .cards {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 30px;
            flex-wrap: wrap;
        }

        .card {
            background: white;
            padding: 25px;
            width: 250px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            transition: 0.3s;
        }

        .card:hover {
            transform: translateY(-8px);
        }

        .card h3 {
            margin-bottom: 10px;
            color: #764ba2;
        }

        footer {
            margin-top: 60px;
            padding: 15px;
            text-align: center;
            background-color: #333;
            color: white;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <div class="navbar">
        <div class="logo">Apni Dukaan</div>
        <div class="nav-links">
            <a href="http://localhost:8080/nav/home">Home</a>
            <a href="http://localhost:8080/nav/about">About</a>
            <a href="http://localhost:8080/contact">Contact</a>
        </div>
    </div>

    <!-- About Section -->
    <section class="about">
        <h1>About Apni Dukaan</h1>
        <p>
            Apni Dukaan is an online shopping platform that connects customers with local vendors.
            Our goal is to provide a smooth shopping experience where users can explore products,
            book appointments, and enjoy home delivery with try-at-home convenience.
        </p>

        <div class="mission">
            <h2>Our Mission</h2>

            <div class="cards">
                <div class="card">
                    <h3>Quality Products</h3>
                    <p>We ensure high-quality products from trusted vendors.</p>
                </div>

                <div class="card">
                    <h3>Fast Delivery</h3>
                    <p>Quick and safe delivery directly to your doorstep.</p>
                </div>

                <div class="card">
                    <h3>Customer Trust</h3>
                    <p>Building trust with secure payments and easy returns.</p>
                </div>
            </div>
        </div>
    </section>

    <footer>
        © 2026 Apni Dukaan | All Rights Reserved
    </footer>

</body>
</html>