<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Apni Dukaan | Home</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', Arial, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #667eea, #764ba2);
            height: 100vh;
        }

        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 60px;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        .logo {
            color: #ffd700;
            font-size: 26px;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            margin-left: 25px;
            font-size: 16px;
            position: relative;
            transition: 0.3s;
        }

        .nav-links a::after {
            content: "";
            position: absolute;
            width: 0%;
            height: 2px;
            bottom: -5px;
            left: 0;
            background-color: #ffd700;
            transition: 0.3s;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        /* Hero Section */
        .hero {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 85vh;
            color: white;
            text-align: center;
            padding: 20px;
        }

        .hero h1 {
            font-size: 55px;
            margin-bottom: 15px;
            text-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        .hero p {
            font-size: 20px;
            margin-bottom: 35px;
            opacity: 0.9;
        }

        .buttons {
            display: flex;
            gap: 25px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn {
            padding: 14px 30px;
            border: none;
            border-radius: 30px;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 500;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .btn-user {
            background: linear-gradient(to right, #ffd700, #ffcc00);
            color: black;
        }

        .btn-vendor {
            background: white;
            color: #764ba2;
        }

        .btn:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }

        /* Footer */
        footer {
            padding: 15px;
            text-align: center;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            font-size: 14px;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <div class="navbar">
        <div class="logo">Apni Dukaan</div>
        <div class="nav-links">
            <a href="http://localhost:8080/nav/home">Home</a>
            <a href="http://localhost:8080/nav/about">About</a>
            <a href="http://localhost:8080/contact">Contact</a>
        </div>
    </div>

    <!-- Hero Section -->
    <div class="hero">
        <h1>Welcome to Apni Dukaan</h1>
        <p>Your One-Stop Online Shopping Platform</p>

        <div class="buttons">
            <form action="/user/login" method="get">
                <button class="btn btn-user" type="submit">
                    Login as a User
                </button>
            </form>

            <form action="/vendor/signup" method="get">
                <button class="btn btn-vendor" type="submit">
                    Login as a Vendor
                </button>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        © 2026 Apni Dukaan | All Rights Reserved
    </footer>

</body>
</html>