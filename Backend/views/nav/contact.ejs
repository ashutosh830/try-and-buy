<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Contact Us | Apni Dukaan</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: linear-gradient(to right, #667eea, #764ba2);
        }

        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 50px;
            background-color: rgba(0,0,0,0.8);
        }

        .logo {
            color: white;
            font-size: 22px;
            font-weight: bold;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
            transition: 0.3s;
        }

        .nav-links a:hover {
            color: #ffd700;
        }

        /* Contact Section */
        .contact-container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 85vh;
        }

        .contact-box {
            background: white;
            padding: 40px;
            width: 400px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .contact-box h2 {
            text-align: center;
            margin-bottom: 20px;
            color: #764ba2;
        }

        .contact-box input,
        .contact-box textarea {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 14px;
        }

        .contact-box textarea {
            resize: none;
            height: 100px;
        }

        .contact-box button {
            width: 100%;
            padding: 12px;
            background-color: #764ba2;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            transition: 0.3s;
        }

        .contact-box button:hover {
            background-color: #5a378c;
        }

        footer {
            text-align: center;
            padding: 10px;
            color: white;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <div class="navbar">
        <div class="logo">Apni Dukaan</div>
        <div class="nav-links">
            <a href="http://localhost:8080/nav/home">Home</a>
            <a href="http://localhost:8080/nav/about">About</a>
            <a href="http://localhost:8080/nav/contact">Contact</a>
        </div>
    </div>

    <!-- Contact Form -->
    <div class="contact-container">
        <div class="contact-box">
            <h2>Contact Us</h2>
            <form action="http://localhost:8080/contact" method="POST">
                <input type="text" name="name" placeholder="Your Name" required>
                <input type="email" name="email" placeholder="Your Email" required>
                <textarea name="message" placeholder="Your Message" required></textarea>
                <button type="submit">Send Message</button>
            </form>
        </div>
    </div>

    <footer>
        © 2026 Apni Dukaan | All Rights Reserved
    </footer>

</body>
</html>